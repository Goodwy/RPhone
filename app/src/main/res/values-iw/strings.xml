    <!-- Project support -->
    <string name="project_support">תמיכה בפרויקט</string>
    <string name="project_support_summary">קבל את האפליקציה בתשלום כדי לתמוך בפיתוחים עתידיים ובתכונות נוספות</string>
    <string name="project_support_description">
        <![CDATA[
        אנו מאמינים שפרטיות צריכה להיות בחינם. לכן כל התכונות החיוניות הן לגמרי שלך מבלי להוציא אגורה.<br>
        אם אתה אוהב את מה שאנו בונים, שקול לקנות לנו קפה. כתודה, תקבל:<br> <b>כל הערכות הנושא, צבעים מותאמים אישית וגופנים מותאמים אישית.</b><br>
        זו לא שכבה פרימיום. זו מחווה של תודה. התמיכה שלך שומרת על Rill עצמאי, פרטי וללא פרסומות.
        ]]>
    </string>
