    <!-- Project support -->
    <string name="project_support">परियोजना समर्थन</string>
    <string name="project_support_summary">भविष्य के विकास और अतिरिक्त सुविधाओं का समर्थन करने के लिए भुगतान ऐप प्राप्त करें</string>
    <string name="project_support_description">
        <![CDATA[
        हमारा मानना है कि गोपनीयता मुफ्त होनी चाहिए। इसलिए सभी आवश्यक सुविधाएँ बिना एक पैसा खर्च किए पूरी तरह से आपकी हैं।<br>
        अगर आपको हमारा काम पसंद है, तो हमें कॉफी खिलाने पर विचार करें। धन्यवाद के रूप में, आपको मिलेगा:<br> <b>सभी थीम, कस्टम रंग और कस्टम फोंट।</b><br>
        यह कोई प्रीमियम स्तर नहीं है। यह एक धन्यवाद इशारा है। आपका समर्थन Rill को स्वतंत्र, निजी और विज्ञापन-मुक्त रखता है।
        ]]>
    </string>
