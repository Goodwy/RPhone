    <!-- Project support -->
    <string name="project_support">פּראָיעקט שטיצע</string>
    <string name="project_support_summary">באַקום די באַצאָלטע אַפּ צו שטיצן צוקונפֿטיקע אַנטוויקלונגען און עקסטרע פֿעאַטורעס</string>
    <string name="project_support_description">
        <![CDATA[
        מיר גלויבן אז פּריוואַטקייט זאָל זײַן פֿרײַ. דערפאַר זענען אַלע וויכטיקע פֿעאַטורעס גאָר דײַנע אָן אַ פּנים.<br>
        אויב די געפֿעלט וואָס מיר בויען, טראַכט אונדז אַ קאַווע צו קויפֿן. ווי אַ דאַנק וועסטו באַקומען:<br> <b>אַלע טעמעס, פּערזענלעכע פֿאַרבן און פּערזענלעכע שריפֿטן.</b><br>
        דאָס איז נישט קיין פּרעמיום סטאַפֿע. דאָס איז אַ דאַנק געבערדע. דײַן שטיצע האַלט Rill אומאָפּהענגיק, פּריוואַט און אָן ווערבונגען.
        ]]>
    </string>
